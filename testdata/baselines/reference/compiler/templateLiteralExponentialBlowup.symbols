//// [tests/cases/compiler/templateLiteralExponentialBlowup.ts] ////

=== templateLiteralExponentialBlowup.ts ===
// Repro from https://github.com/microsoft/TypeScript/issues/63271
// Template literal types that double in size each recursion step should not
// consume unbounded memory.

type Dec<N extends number> = 
>Dec : Symbol(Dec, Decl(templateLiteralExponentialBlowup.ts, 0, 0))
>N : Symbol(N, Decl(templateLiteralExponentialBlowup.ts, 4, 9))

    N extends 5 ? 4 : N extends 4 ? 3 : N extends 3 ? 2 : 
>N : Symbol(N, Decl(templateLiteralExponentialBlowup.ts, 4, 9))
>N : Symbol(N, Decl(templateLiteralExponentialBlowup.ts, 4, 9))
>N : Symbol(N, Decl(templateLiteralExponentialBlowup.ts, 4, 9))

    N extends 2 ? any : 
>N : Symbol(N, Decl(templateLiteralExponentialBlowup.ts, 4, 9))

    N extends 1 ? 0 : 0;
>N : Symbol(N, Decl(templateLiteralExponentialBlowup.ts, 4, 9))

type Recur<N extends number, S extends string> = 
>Recur : Symbol(Recur, Decl(templateLiteralExponentialBlowup.ts, 7, 24))
>N : Symbol(N, Decl(templateLiteralExponentialBlowup.ts, 9, 11))
>S : Symbol(S, Decl(templateLiteralExponentialBlowup.ts, 9, 28))

    N extends 0 ? S : Recur<Dec<N>, `${S}_${S}`>;
>N : Symbol(N, Decl(templateLiteralExponentialBlowup.ts, 9, 11))
>S : Symbol(S, Decl(templateLiteralExponentialBlowup.ts, 9, 28))
>Recur : Symbol(Recur, Decl(templateLiteralExponentialBlowup.ts, 7, 24))
>Dec : Symbol(Dec, Decl(templateLiteralExponentialBlowup.ts, 0, 0))
>N : Symbol(N, Decl(templateLiteralExponentialBlowup.ts, 9, 11))
>S : Symbol(S, Decl(templateLiteralExponentialBlowup.ts, 9, 28))
>S : Symbol(S, Decl(templateLiteralExponentialBlowup.ts, 9, 28))

type Explode = {
>Explode : Symbol(Explode, Decl(templateLiteralExponentialBlowup.ts, 10, 49))

    [P in Recur<5, "a"> as `${P}_key`]: any;
>P : Symbol(P, Decl(templateLiteralExponentialBlowup.ts, 13, 5))
>Recur : Symbol(Recur, Decl(templateLiteralExponentialBlowup.ts, 7, 24))
>P : Symbol(P, Decl(templateLiteralExponentialBlowup.ts, 13, 5))

};

