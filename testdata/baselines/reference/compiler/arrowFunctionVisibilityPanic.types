>() => {    interface PrivateType {        secret: string;    }    return (p: PrivateType) => p;} : () => (p: PrivateType) => PrivateType

    interface PrivateType {
        secret: string;
>secret : string
    }
    return (p: PrivateType) => p;
>(p: PrivateType) => p : (p: PrivateType) => PrivateType
>p : PrivateType
