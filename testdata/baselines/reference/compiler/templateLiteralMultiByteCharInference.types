//// [tests/cases/compiler/templateLiteralMultiByteCharInference.ts] ////

=== templateLiteralMultiByteCharInference.ts ===
// Verifies that template literal type inference handles multi-byte characters correctly,
// slicing by UTF-16 code unit instead of by byte.

type GetFirst<S extends string> = S extends `${infer Head}${string}` ? Head : never;
>GetFirst : GetFirst<S>

type GetRest<S extends string> = S extends `${string}${infer Rest}` ? Rest : never;
>GetRest : GetRest<S>

type Split<S extends string> = S extends `${infer Head}${infer Rest}` ? [Head, Rest] : never;
>Split : Split<S>

// Single-byte (ASCII) characters
type A = GetFirst<"ABC">;  // "A"
>A : "A"

type BC = GetRest<"ABC">;  // "BC"
>BC : "BC"

type ABC_Split = Split<"ABC">;  // ["A", "BC"]
>ABC_Split : ["A", "BC"]

// Multi-byte characters (Japanese, 3 bytes in UTF-8, 1 code unit in UTF-16)
type Ah = GetFirst<"„Āā„ĀĄ„ĀÜ">;  // "„Āā"
>Ah : "„"

type IU = GetRest<"„Āā„ĀĄ„ĀÜ">;  // "„ĀĄ„ĀÜ"
>IU : "Āā„ĀĄ„ĀÜ"

type AIU_Split = Split<"„Āā„ĀĄ„ĀÜ">;  // ["„Āā", "„ĀĄ„ĀÜ"]
>AIU_Split : ["„", "Āā„ĀĄ„ĀÜ"]

// Mixed single-byte and multi-byte
type M1 = GetFirst<"a„Āā">;  // "a"
>M1 : "a"

type M2 = GetFirst<"„Āāa">;  // "„Āā"
>M2 : "„"

// 2-byte UTF-8 characters (Latin Extended, 1 code unit in UTF-16)
type E = GetFirst<"√©√†√ľ">;  // "√©"
>E : "√"

// Emoji (4 bytes in UTF-8, 2 code units in UTF-16 as surrogate pair)
type Emoji = GetFirst<"ūüėÄabc">;
>Emoji : "ū"

// Verification
type Expect<T, Expected> = T extends Expected ? true : false;
>Expect : Expect<T, Expected>
>true : true
>false : false

const check1: Expect<A, "A"> = true;
>check1 : true
>true : true

const check2: Expect<Ah, "„Āā"> = true;
>check2 : false
>true : true

const check3: Expect<BC, "BC"> = true;
>check3 : true
>true : true

const check4: Expect<IU, "„ĀĄ„ĀÜ"> = true;
>check4 : false
>true : true

const check5: Expect<M1, "a"> = true;
>check5 : true
>true : true

const check6: Expect<M2, "„Āā"> = true;
>check6 : false
>true : true

const check7: Expect<E, "√©"> = true;
>check7 : false
>true : true

