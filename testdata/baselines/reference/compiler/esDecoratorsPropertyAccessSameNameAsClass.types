=== esDecoratorsPropertyAccessSameNameAsClass.ts ===
export enum MyEnum {
>MyEnum : MyEnum

    Foo = "FooValue",
>Foo : MyEnum.Foo
>"FooValue" : "FooValue"

    Bar = "BarValue",
>Bar : MyEnum.Bar
>"BarValue" : "BarValue"
}

function myDecorator(target: any, context: ClassDecoratorContext) {
>myDecorator : (target: any, context: ClassDecoratorContext<abstract new (...args: any) => any>) => any
>target : any
>context : ClassDecoratorContext<abstract new (...args: any) => any>

    return target;
>target : any
}

// ES decorators with enum member access sharing a class name
@myDecorator
>myDecorator : (target: any, context: ClassDecoratorContext<abstract new (...args: any) => any>) => any

export class Foo {
>Foo : Foo

    type: MyEnum = MyEnum.Foo;
>type : MyEnum
>MyEnum.Foo : MyEnum.Foo
>MyEnum : typeof MyEnum
>Foo : MyEnum.Foo

    getType(): MyEnum {
>getType : () => MyEnum

        return this.type || MyEnum.Foo;
>this.type || MyEnum.Foo : MyEnum
>this.type : MyEnum
>this : this
>type : MyEnum
>MyEnum.Foo : MyEnum.Foo
>MyEnum : typeof MyEnum
>Foo : MyEnum.Foo
    }
}

// Property access on objects
declare const obj: { Bar: string };
>obj : { Bar: string; }
>Bar : string

@myDecorator
>myDecorator : (target: any, context: ClassDecoratorContext<abstract new (...args: any) => any>) => any

export class Bar {
>Bar : Bar

    prop = obj.Bar;
>prop : string
>obj.Bar : string
>obj : { Bar: string; }
>Bar : string

    method() {
>method : () => string

        return obj.Bar;
>obj.Bar : string
>obj : { Bar: string; }
>Bar : string
    }
}

// Static member of another class
class Other {
>Other : Other

    static Baz = 42;
>Baz : number
>42 : 42
}

@myDecorator
>myDecorator : (target: any, context: ClassDecoratorContext<abstract new (...args: any) => any>) => any

export class Baz {
>Baz : Baz

    prop = Other.Baz;
>prop : number
>Other.Baz : number
>Other : typeof Other
>Baz : number
}

