//// [tests/cases/compiler/checkJsJSDocModifiersInClass.ts] ////

=== test.js ===
// Unlike object literal members, JSDoc modifiers on class members are still
// semantically validated under checkJs: @override without a base class errors.

class NoBase {
>NoBase : Symbol(NoBase, Decl(test.js, 0, 0))

  /** @override */
  foo() {
>foo : Symbol(NoBase.foo, Decl(test.js, 3, 14))
  }
}

class Base {
>Base : Symbol(Base, Decl(test.js, 7, 1))

  foo() {
>foo : Symbol(Base.foo, Decl(test.js, 9, 12))
  }
}

class Derived extends Base {
>Derived : Symbol(Derived, Decl(test.js, 12, 1))
>Base : Symbol(Base, Decl(test.js, 7, 1))

  /** @override */
  foo() {
>foo : Symbol(Derived.foo, Decl(test.js, 14, 28))
  }
}

