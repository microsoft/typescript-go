=== recursiveTupleTypeWithSpreadOverflow.ts ===
// Repro from #63270 - should not crash with stack overflow

type Recur<T> = (
>Recur : Recur<T>

    T extends (unknown[]) ? {} : { [K in keyof T]?: Recur<T> }
) | [...Recur<T>[number][]];

function join<T>(l: Recur<T>[]): Recur<T> {
>join : <T>(l: Recur<T>[]) => Recur<T>
>l : Recur<T>[]

    return ['marker', ...l];
>['marker', ...l] : [string, ...Recur<T>[]]
>'marker' : "marker"
>...l : Recur<T>
>l : Recur<T>[]
}

function a<T>(l: Recur<T>[]): void {
>a : <T>(l: Recur<T>[]) => void
>l : Recur<T>[]

    const x: Recur<T> | undefined = join(l);
>x : Recur<T> | undefined
>join(l) : Recur<T>
>join : <T_1>(l: Recur<T_1>[]) => Recur<T_1>
>l : Recur<T>[]
}

