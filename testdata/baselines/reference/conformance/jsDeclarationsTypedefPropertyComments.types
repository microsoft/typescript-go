/**
 * @typedef {Object} Foo
 * @property {boolean} bool Whether `.bool` is true or not
 */
export class C {
>C : C

    /** @returns {Foo} */
    getFoo() { return { bool: false }; }
>getFoo : () => Foo
>{ bool: false } : { bool: false; }
>bool : false
>false : false
}

=== main.js ===
import { C } from './lib.js';
>C : typeof C

export class Main {
>Main : Main

    constructor() {
        this.c = new C();
>this.c = new C() : C
>this.c : any
>this : this
>c : any
>new C() : C
